{
  "name": "brx-system",
  "version": "2.0.0",
  "description": "BRX SYSTEM - Open Source AI Integration Platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "api:dev": "cd apps/api && uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
    "api:prod": "cd apps/api && gunicorn src.main:app -w 4 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:8000",
    "web:dev": "cd apps/web && vite --host",
    "web:build": "cd apps/web && tsc && vite build",
    "worker:dev": "cd apps/worker && celery -A src.worker worker -l info",
    "worker:beat": "cd apps/worker && celery -A src.worker beat -l info",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "db:migrate": "cd apps/api && alembic upgrade head",
    "db:reset": "cd apps/api && alembic downgrade base && alembic upgrade head",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "python": ">=3.10"
  }
}
